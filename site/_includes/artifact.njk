---
layout: base.njk
---

{% block content %}
	<script>
		document
			.documentElement
			.classList
			.add('booting-list-replace');
	</script>
	<style>
		html.booting-list-replace main {
			visibility: hidden;
		}
	</style>
	<link rel="stylesheet" href="/assets/css/artifacts.css">
	<div class="artifact-content">
		<h1>{{ title }}</h1>
		<h4 class="artifact-subtitle">
			<i>{{ time }}. {{ subtitle }}</i>
		</h4>
		{#
        {% if image %}
            <img src="{{ image }}" alt="{{ title }} image" style="max-width:400px;display:block;">
        {% endif %}
        #}
		{{ content | safe }}
	</div>
{% endblock %}

{# If this artifact page is visited directly (pretty URL), boot the list view
   by fetching the homepage and initializing the list+detail UI purely client-side. #}
<script type="module">
	/* Client-side boot for pretty URLs: if a user opens /artifacts/name/ directly,
   fetch the list page, replace the body with the list layout, and initialize
   the list loader so the detail panel shows this artifact without a full server-side
   rewrite. This is a JS-only solution to enable pretty URLs while keeping the
   interactive list/detail UX. */
	// load a script by appending a <script> tag — unlike innerHTML, this actually executes
	function loadScript(src) {
		return new Promise((resolve, reject) => {
			const s = document.createElement('script')
			s.src = src
			s.onload = resolve
			s.onerror = reject
			document
				.head
				.appendChild(s)
		})
	}

	import ('/assets/js/home.js').then(async (m) => {
		// on narrow screens, skip body replacement — show server-rendered artifact page as-is
		if (window.matchMedia('(max-width: 800px)').matches) {
			document
				.documentElement
				.classList
				.remove('booting-list-replace')
			return
		}
		try {
			const currentPath = location.pathname + location.search
			// fetch the homepage (list) HTML
			const res = await fetch('/')
			if (!res.ok) 
				throw new Error('fetch / failed: ' + res.status)
			const text = await res.text()
			const parser = new DOMParser()
			const doc = parser.parseFromString(text, 'text/html')
			const newBody = doc.body
			if (!newBody) 
				throw new Error('no body in fetched homepage')
				// Replace current body with the homepage body content
			document.body.innerHTML = newBody.innerHTML
			// done booting: reveal main content
			document
				.documentElement
				.classList
				.remove('booting-list-replace')
			// load GSAP + animations for the fly-in and hover effects
			// if it fails, fall back to making cards visible manually
			let animationsLoaded = false
			try {
				await loadScript('/assets/js/bg-particles.js')
				await loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js')
				await loadScript('/assets/js/animations.js')
				animationsLoaded = true
			} catch (animErr) {
				console.warn('animations/particles failed to load', animErr)
			}
			if (!animationsLoaded) {
				// GSAP didn't load — cards stay at opacity:0 from CSS, make them visible
				document.querySelectorAll('.grid-entry').forEach(el => { el.style.opacity = '1' })
			}
			// init list module and open this artifact in the detail panel
			if (m && typeof m.init === 'function') {
				m.init()
				if (typeof m.openDetail === 'function') {
					m.openDetail(currentPath, false)
					history.replaceState({
						href: currentPath
					}, '', currentPath)
				}
			}
		} catch (err) {
			// boot failed — reveal the server-rendered artifact page as fallback
			console.error('booting list view failed', err)
			document
				.documentElement
				.classList
				.remove('booting-list-replace')
		}
	})
</script>